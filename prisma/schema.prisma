generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Existing desktop app tables (kept so db push doesn't drop them) ──

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model code_bindings {
  code         String    @id
  hwid         String
  bound_at     DateTime? @default(now()) @db.Timestamptz(6)
  last_seen_at DateTime? @default(now()) @db.Timestamptz(6)
  code_hash    String?   @unique(map: "idx_code_bindings_hash")

  @@ignore
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// Managed directly in Supabase (not by Prisma migrations). Keep @@ignore.
model license_keys {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  license_key       String    @unique
  user_id           String?   @db.Uuid
  hwid              String?
  tier              String?   @default("standard")
  status            String?   @default("active")
  email             String?
  display_name      String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  activated_at      DateTime? @db.Timestamptz(6)
  expires_at        DateTime? @db.Timestamptz(6)
  trial_expires_at  DateTime? @db.Timestamptz(6)
  account_id        String?
  license_signature String?
  payment_provider  String?
  payment_order_id  String?
  payment_amount    String?
  payment_currency  String?   @default("GBP")
  paid_at           DateTime? @db.Timestamptz(6)

  @@ignore
}

model profiles {
  id         String    @id @db.Uuid
  username   String?   @unique
  email      String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@ignore
}

model subscriptions {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id String? @db.Uuid
  tier    String? @default("free")
  status  String? @default("active")

  @@ignore
}

// ── Website tables ──

model User {
  id            String        @id @default(cuid())
  clerkId       String        @unique
  email         String        @unique
  name          String?
  image         String?
  role          String        @default("user")
  emailVerified DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  subscription  Subscription?
  licenses      License[]
  activities    Activity[]
  reviews       Review[]
  visitors      Visitor[]
  payments      Payment[]
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String    @unique
  stripeSubscriptionId String    @unique
  stripePriceId        String
  status               String
  tier                 String
  interval             String    @default("month")
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  trialStart           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model License {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  key         String    @unique
  tier        String
  email       String
  isActive    Boolean   @default(true)
  isLifetime  Boolean   @default(false)
  expiresAt   DateTime?
  activatedAt DateTime?
  hwid        String?
  ipAddress   String?
  country     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payments    Payment[]
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model Video {
  id           String   @id @default(cuid())
  title        String
  game         String
  duration     String?
  url          String
  thumbnailUrl String?
  uploadedBy   String
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      @default(5)
  content   String
  tier      String   @default("pro")
  game      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  licenseId   String?
  license     License? @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  provider    String   // stripe, paypal, manual
  orderId     String?
  amount      Float
  currency    String   @default("GBP")
  status      String   @default("completed")
  payerEmail  String
  ipAddress   String?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([licenseId])
  @@index([createdAt])
  @@index([provider])
}

model Visitor {
  id          String     @id @default(cuid())
  visitorId   String     @unique
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstSeen   DateTime   @default(now())
  lastSeen    DateTime   @updatedAt
  visitCount  Int        @default(0)
  country     String?
  city        String?
  region      String?
  ip          String?
  userAgent   String?
  device      String?
  browser     String?
  os          String?
  referrer    String?
  source      String?
  pageViews   PageView[]

  @@index([visitorId])
  @@index([userId])
  @@index([firstSeen])
}

model PageView {
  id          String   @id @default(cuid())
  visitorId   String
  visitor     Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  path        String
  referrer    String?
  country     String?
  ip          String?
  userAgent   String?
  device      String?
  browser     String?
  os          String?
  createdAt   DateTime @default(now())

  @@index([visitorId])
  @@index([createdAt])
  @@index([path])
}
